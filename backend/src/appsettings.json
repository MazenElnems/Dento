{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Formatting.Compact" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName", "WithThreadId", "WithProcessId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 2,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Properties": {
      "Application": "AiLern Web APIs"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;Initial Catalog=DentoApiDB;Integrated Security=True;Encrypt=False;Trust Server Certificate=True"
  },
  "JWTSettings": {
    "Issuer": "MyBGList",
    "Audience": "MyBGList"
  },
  "MailSettings": {
    "Email": "dento.mail.support@gmail.com",
    "DisplayName": "Dento Platform",
    "Host": "smtp.gmail.com",
    "Port": 587
  },
  "PaymobSettings": {
    "BaseUrl": "https://accept.paymob.com",
    "CreatePaymentIntentPath": "v1/intention",
    "WebhookEndpointUrl": "api/webhooks/paymob",
    "CheckoutPageUrl": "unifiedcheckout"
  }
}
